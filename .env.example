# Real viewer counts use Firebase Realtime Database.
# 1. Create a free project at https://console.firebase.google.com
# 2. Add a Web App, enable "Realtime Database" (start in test mode), and copy these values:
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_DATABASE_URL=
VITE_FIREBASE_PROJECT_ID=

# Without these set, the app runs fine but hides the viewer count entirely.
