# Real viewer counts use Firebase Realtime Database.
# 1. Create a free project at https://console.firebase.google.com
# 2. Add a Web App, enable "Realtime Database" (start in test mode), and copy these values:
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_DATABASE_URL=
VITE_FIREBASE_PROJECT_ID=

# Without these set, the app runs fine but hides the viewer count entirely.

# Stream proxy (see server/) — fixes CORS-blocked and mixed-content (http on
# https) channels by fetching them server-side. Defaults to localhost for dev.
# Deploy server/ anywhere (Render, Railway, Fly.io, a VPS...) and point this at
# its public https URL before building for production.
VITE_PROXY_BASE=http://localhost:8787

# Google Analytics (GA4) — page views + channel-play events.
# Create a GA4 property at https://analytics.google.com, add a Web data stream,
# and paste its Measurement ID (looks like G-XXXXXXXXXX) below.
# Without this set, no GA script loads at all — zero tracking, zero cost.
VITE_GA_MEASUREMENT_ID=
